#!/bin/sh
# Pre-push hook for Aevum: run build checks before pushing.

cd "$(git rev-parse --show-toplevel)/aevum-app" || exit 1
if [ -x "./node_modules/.bin/vite" ] && [ -x "./node_modules/.bin/tsc" ]; then
  echo "Running build validation..."
  npm run build || {
    echo "Build failed. Fix issues before pushing."
    exit 1
  }
else
  echo "Warning: dependencies not installed in aevum-app. Run npm install first."
fi
